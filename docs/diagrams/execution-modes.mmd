flowchart TD
    A["TaskRunner config"] --> B{"use_multiprocessing?"}

    B -- "False" --> C["Thread worker"]
    C --> D["execution_mode = thread"]
    D --> E["Shared parent memory + GIL-bound"]

    B -- "True" --> F{"Task picklable?"}

    F -- "Yes" --> G["Process worker"]
    G --> H["execution_mode = process"]
    H --> I["Process isolation + CPU parallelism"]

